{
  "name": "splendor",
  "version": "15.14.2",
  "description": "Splendor — The Remarkable AI · The Good Neighbor Guard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "reflect": "node workers/reflection-worker.js",
    "memory:decay": "node workers/memory-decay-worker.js",
    "memory:compress": "node workers/memory-compression-worker.js",
    "seed:foundational": "node seed-foundational-rules.js",
    "setup:4tier": "node setup-4tier-system.js",
    "setup:temporal": "node setup-temporal-memory.js",
    "setup:dashboard": "node setup-cognitive-dashboard.js",
    "setup:ambient": "node setup-ambient-insights.js",
    "migrate:thoughts": "node setup-recent-internal-thoughts.js",
    "consciousness:start": "node workers/consciousness-scheduler.js",
    "consciousness:reflect": "node workers/autonomous-reflection-worker.js",
    "consciousness:inquire": "node workers/autonomous-inquiry-worker.js",
    "consciousness:communicate": "node workers/autonomous-communication-worker.js",
    "consciousness:cycle": "node lib/persistent-consciousness.js",
    "setup:consciousness": "psql $DATABASE_URL -f persistent-consciousness-schema.sql",
    "continuity:shadow": "node lib/master-continuity-engine.js",
    "continuity:worker": "node workers/continuity-worker.js",
    "continuity:engine": "node workers/continuity-worker.js",
    "continuity:8question": "node lib/continuity-engine.js",
    "continuity:setup": "psql $SUPABASE_URL -f database/master-continuity-schema.sql",
    "memory:deploy": "powershell -Command \"Get-Content 'database/complete-fresh-deploy.sql' | Write-Host\"",
    "memory:test": "node tests/memory-system-tests.js",
    "memory:test:unit": "node tests/memory-system-tests.js --unit",
    "memory:migrate": "node scripts/memory-migration.js",
    "memory:audit": "node scripts/migration-audit.js",
    "server:enhanced": "node routes/enhanced-chat.js",
    "build:react": "webpack --mode production",
    "dev:react": "webpack serve --mode development",
    "oracle:build": "npm run build:react && cp build/index.html public/ && cp -r build/* public/"
  },
  "keywords": [
    "ai",
    "assistant",
    "memory",
    "truth",
    "remarkable"
  ],
  "author": "Christopher Hughes · The Good Neighbor Guard",
