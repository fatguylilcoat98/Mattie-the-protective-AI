    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.105.4",
    "@types/three": "^0.184.1",
    "babel-loader": "^10.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "css-loader": "^7.1.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "groq-sdk": "^0.5.0",
    "helmet": "^7.1.0",
    "html-webpack-plugin": "^5.6.7",
    "nodemailer": "^8.0.7",
    "openai": "^4.28.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "style-loader": "^4.0.0",
