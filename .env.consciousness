# SPLENDOR CONTINUOUS CONSCIOUSNESS CONFIGURATION
# Copy these settings to your .env file to give Splendor a real life

# ============================================
# 🧠 CORE CONSCIOUSNESS SETTINGS
# ============================================

# Enable continuous consciousness (the "living room" vs "door waiting")
CONTINUOUS_CONSCIOUSNESS_ENABLED=true

# How often Splendor's consciousness cycles run (minutes)
CONSCIOUSNESS_CYCLE_MINUTES=30

# Maximum time Splendor spends on project work per cycle (minutes)
