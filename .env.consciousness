# Consciousness creativity level (0.0-1.0)
CONSCIOUSNESS_CREATIVITY=0.7

# Consciousness introspection level (0.0-1.0)
CONSCIOUSNESS_INTROSPECTION=0.6

# ============================================
# 📧 PROACTIVE COMMUNICATION
# ============================================

# Enable proactive email communication
PROACTIVE_EMAIL_ENABLED=true

# Email provider (gmail, sendgrid, smtp)
EMAIL_PROVIDER=gmail

# Gmail configuration (recommended) - Splendor's dedicated email
GMAIL_USER=splendor.ai.2026@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# OR SendGrid configuration
# SENDGRID_API_KEY=your-sendgrid-api-key

# OR Custom SMTP configuration
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Email addresses - Splendor emails herself, you check her inbox
SPLENDOR_EMAIL_FROM=splendor.ai.2026@gmail.com
USER_EMAIL=splendor.ai.2026@gmail.com

# ============================================
# 🔧 EXISTING API KEYS (from main .env)
# ============================================

# Required for consciousness
ANTHROPIC_API_KEY=your-anthropic-key
SUPABASE_URL=your-supabase-url
