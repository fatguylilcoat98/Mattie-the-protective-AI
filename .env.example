# Splendor — The Remarkable AI Environment Variables
# Copy this to .env and fill in your values

# AI Provider APIs
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Supabase Frontend Configuration (exposed to browser via webpack DefinePlugin)
# These should have the SAME VALUES as SUPABASE_URL and SUPABASE_ANON_KEY above
# The _PUBLIC_ prefix makes it clear these values end up in the JS bundle
SPLENDOR_PUBLIC_SUPABASE_URL=your_supabase_url_here
SPLENDOR_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Pinecone Configuration (Semantic Memory)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=splendor-memory

# Tavily Configuration (Web Search)
TAVILY_API_KEY=your_tavily_api_key_here

# ElevenLabs (Voice — falls back to browser TTS if missing)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# ModelsLab Configuration (Video Generation)
MODELSLAB_API_KEY=your_modelslab_api_key_here

# CLASPION Governance (bolt-on middleware) ──────────────────────────────
# Splendor reasons normally; when enabled, CLASPION validates each
# action she is about to take. Flip CLASPION_ENABLED to false (or unset)
# to make CLASPION dormant — Splendor runs clean without it.
#
# CLASPION_FAIL_MODE controls behavior when CLASPION is unreachable:
#   block (default) — fail-closed; Splendor returns a safe refusal
#   allow           — fail-open; ONLY use during testing
CLASPION_ENABLED=false
CLASPION_URL=http://localhost:8000
CLASPION_API_KEY=
CLASPION_TIMEOUT_MS=1500
CLASPION_FAIL_MODE=block
CLASPION_ACTOR_ID=splendor
